{
    "require": {
        "edwardspec/mediawiki-aws-s3": "0.14.*",
        "mediawiki/pluggable-auth": "7.5.0",
        "mediawiki/openidconnect": "dev-REL1_46",
        "mediawiki/simple-s-a-m-lphp": "dev-REL1_46"
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/wikimedia/mediawiki-extensions-PluggableAuth.git"
        },
        {
            "type": "git",
            "url": "https://github.com/wikimedia/mediawiki-extensions-OpenIDConnect.git"
        },
        {
            "type": "git",
            "url": "https://github.com/wikimedia/mediawiki-extensions-SimpleSAMLphp.git"
        }
    ],
    "extra": {
        "merge-plugin": {
            "include": [
                "composer.user.json",
                "extensions/*/composer.json",
                "skins/*/composer.json"
            ]
        }
    }
}
